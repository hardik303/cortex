[database]
# PostgreSQL connection URL
url = "postgres://screenpipe:screenpipe@localhost:5432/screenpipe"

[capture]
# Seconds between screen captures (supports fractional values, e.g. 0.5 = 500ms)
interval_secs = 5.0

[kg]
# Ollama endpoint for local LLM NER. Set empty string "" to disable LLM extraction.
ollama_endpoint = "http://localhost:11434"
# Ollama model to use for NER (must be pulled: ollama pull deepseek-r1:7b)
ollama_model = "deepseek-r1:7b"
# Anthropic API key — used only by the cortex-query binary for answer synthesis.
anthropic_api_key = ""
# Minutes of inactivity that defines a session boundary
session_gap_mins = 30
# Days to keep raw OCR text before expiring (setting to NULL)
ocr_ttl_days = 14
# Fraction of frames to send to Ollama NER (1.0 = every frame, 0.5 = every other frame)
llm_sample_rate = 1.0
